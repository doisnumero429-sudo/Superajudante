# Variaveis de ambiente — adicione TODAS na Vercel (Settings -> Environment Variables).
# NUNCA suba este arquivo preenchido para o GitHub.

# API Meu Danfe v2
API_KEY_MEU_DANFE=cole_sua_chave_aqui
BASE_URL_API=https://api.meudanfe.com.br/v2

# Supabase — use a service_role key (nunca a anon key no servidor)
# Encontre em: Supabase Dashboard -> Settings -> API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# IA opcional — Google Gemini (gratuito). Sugere nome/categoria/unidade/fator de
# produtos novos na conferencia. Gere em: https://aistudio.google.com/apikey
# Sem esta chave, o app funciona normal (so o botao de IA fica indisponivel).
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash  # opcional, este e o padrao
